  <style>
    :root {
      --red: #e63946;
      --dark: #0d0d0d;
      --gray: #161616;
      --gray2: #1e1e1e;
      --border: #2a2a2a;
      --text: #f1faee;
      --muted: #666;
      --accent: #f5a623;
      --green: #2ecc71;
      --blue: #4dadff;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--dark);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .header {
      width: 100%;
      background: var(--gray);
      border-bottom: 2px solid var(--red);
      padding: 14px 20px;
      text-align: center;
      letter-spacing: 3px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px;
    }
    .header span { color: var(--red); }
    .tabs {
      width: 100%;
      max-width: 480px;
      display: flex;
      padding: 14px 14px 0;
      overflow-x: auto;
    }
    .tab {
      flex: 1;
      padding: 9px 4px;
      text-align: center;
      font-size: 10px;
      font-family: 'IBM Plex Mono', monospace;
      color: var(--muted);
      cursor: pointer;
      border-bottom: 2px solid var(--border);
      white-space: nowrap;
      transition: all 0.2s;
    }
    .tab.active { color: var(--red); border-bottom-color: var(--red); }
    .section { display: none; width: 100%; max-width: 480px; padding: 14px; flex-direction: column; gap: 12px; }
    .section.active { display: flex; animation: fade 0.3s ease; }
    @keyframes fade { from { opacity: 0; } to { opacity: 1; } }
    .card { background: var(--gray2); border: 1px solid var(--border); border-radius: 14px; padding: 16px; }
    .card-title {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      color: var(--red);
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .card-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .clima-wrap { border-radius: 10px; overflow: hidden; margin-bottom: 12px; border: 1px solid var(--border); }
    .weatherwidget-io { display: block; }
    .ciudad-chip {
      padding: 7px 12px;
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 20px;
      font-size: 10px;
      font-family: 'IBM Plex Mono', monospace;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.2s;
    }
    .ciudad-chip.active { border-color: var(--red); color: var(--red); }
    .ruta-btn {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 16px;
      text-decoration: none;
      color: var(--text);
      margin-bottom: 8px;
      cursor: pointer;
      transition: all 0.18s;
      position: relative;
      overflow: hidden;
    }
    .ruta-btn::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--red);
      transform: scaleY(0);
      transition: transform 0.18s;
    }
    .ruta-btn:hover::before, .ruta-btn:active::before { transform: scaleY(1); }
    .ruta-btn:hover, .ruta-btn:active { border-color: var(--red); }
    .ruta-icon { font-size: 22px; width: 34px; text-align: center; flex-shrink: 0; }
    .ruta-title { font-size: 14px; font-weight: 700; display: block; }
    .ruta-sub { font-size: 10px; color: var(--muted); font-family: 'IBM Plex Mono', monospace; }
    .ruta-arrow { margin-left: auto; color: var(--muted); }
    .calc-input {
      width: 100%;
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 14px;
      color: var(--text);
      font-size: 14px;
      font-family: 'IBM Plex Mono', monospace;
      outline: none;
      margin-bottom: 8px;
      transition: border-color 0.15s;
    }
    .calc-input:focus { border-color: var(--red); }
    .calc-btn {
      width: 100%;
      padding: 14px;
      background: var(--red);
      color: white;
      border: none;
      border-radius: 10px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px;
      letter-spacing: 2px;
      cursor: pointer;
    }
    .calc-result {
      display: none;
      margin-top: 12px;
      padding: 14px;
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 10px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
      line-height: 2;
    }
    .calc-result.show { display: block; }
    .pulso-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 11px 13px;
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 9px;
      margin-bottom: 8px;
      font-size: 12px;
    }
    .pulso-item:last-child { margin-bottom: 0; }
    .dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; margin-right: 8px; }
    .dot-g { background: var(--green); box-shadow: 0 0 5px var(--green); }
    .dot-y { background: var(--accent); box-shadow: 0 0 5px var(--accent); }
    .dot-r { background: var(--red); box-shadow: 0 0 5px var(--red); }
    .pulso-val { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--muted); }
    .chat-box { background: var(--dark); border: 1px solid var(--border); border-radius: 10px; height: 300px; display: flex; flex-direction: column; }
    .chat-messages { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    .msg { max-width: 85%; padding: 8px 12px; border-radius: 10px; font-size: 12px; line-height: 1.5; }
    .msg.other { background: var(--gray2); border: 1px solid var(--border); align-self: flex-start; border-radius: 4px 10px 10px 10px; }
    .msg.me { background: var(--red); color: #fff; align-self: flex-end; border-radius: 10px 4px 10px 10px; }
    .msg-name { font-size: 9px; color: var(--muted); font-family: 'IBM Plex Mono', monospace; margin-bottom: 3px; }
    .chat-input-row { display: flex; gap: 8px; padding: 10px; border-top: 1px solid var(--border); }
    .chat-input { flex: 1; background: var(--gray2); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; color: var(--text); font-size: 13px; outline: none; }
    .chat-input:focus { border-color: var(--red); }
    .chat-send { background: var(--red); color: #fff; border: none; border-radius: 8px; padding: 10px 16px; font-size: 16px; cursor: pointer; }
    .sos-btn {
      display: block; width: 100%; padding: 22px; background: var(--red); color: #fff;
      border: none; border-radius: 14px; font-family: 'Bebas Neue', sans-serif;
      font-size: 22px; letter-spacing: 3px; text-align: center; text-decoration: none;
      cursor: pointer; animation: glow 2s infinite; margin-bottom: 12px;
    }
    @keyframes glow {
      0%   { box-shadow: 0 0 0 0 rgba(230,57,70,0.6); }
      70%  { box-shadow: 0 0 0 14px rgba(230,57,70,0); }
      100% { box-shadow: 0 0 0 0 rgba(230,57,70,0); }
    }
    .gps-status { font-size: 10px; color: var(--accent); font-family: 'IBM Plex Mono', monospace; text-align: center; padding: 8px 4px; }
    .footer { padding: 24px 16px; font-size: 10px; color: var(--muted); font-family: 'IBM Plex Mono', monospace; letter-spacing: 1px; text-align: center; }
  </style>
</head>
